# 推荐开发环境配置（避免 CORS）：
# - 浏览器请求同源 /api/...
# - Vite 开发服务器把 /api 转发到 VITE_API_PROXY_TARGET
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=https://n.lconai.com

# 完整的 Authorization 头，例如：Bearer sk-xxx
VITE_AUTHORIZATION="Bearer sk-xxx"

# 或者只填 key（会自动拼成 Bearer ${VITE_API_KEY}）
# VITE_API_KEY=sk-xxx

# 默认生图模型（当请求未传 model 时使用）
# 建议先用：gemini-2.5-flash-image（如分组不支持，可改为 gpt-image-1.5）
VITE_DEFAULT_IMAGE_MODEL=gemini-2.5-flash-image
