# 推荐开发环境配置（避免 CORS）：
# - 浏览器请求同源 /api 和 /auth
# - Vite 开发服务器把它们都转发到本地 auth server
VITE_API_BASE_URL=/api

# 默认生图模型（当请求未传 model 时使用）
# 建议先用：gemini-2.5-flash-image（如分组不支持，可改为 gpt-image-1.5）
VITE_DEFAULT_IMAGE_MODEL=gemini-2.5-flash-image
# 前端图片请求超时（毫秒，默认 120000）
VITE_IMAGE_FETCH_TIMEOUT_MS=120000
# 前端图片请求最大重试次数（默认 1，拥塞/降级时会自动收敛到 0）
VITE_IMAGE_REQUEST_RETRIES=1
# 重试基准延迟（毫秒，默认 800）
VITE_IMAGE_RETRY_BASE_DELAY_MS=800
# 重试最大延迟（毫秒，默认 4000）
VITE_IMAGE_RETRY_MAX_DELAY_MS=4000
# 模型 fallback 缓存 TTL（毫秒，默认 300000）
VITE_MODEL_FALLBACK_CACHE_TTL_MS=300000
# 余额自动刷新最小间隔（毫秒，默认 60000）
VITE_BALANCE_REFRESH_MIN_INTERVAL_MS=60000
# 模型列表最小刷新间隔（毫秒，默认 300000）
VITE_MODELS_REFRESH_MIN_INTERVAL_MS=300000
# 生成队列最大排队数（默认 20，超过会快速失败）
VITE_CHAT_QUEUE_MAX_PENDING=20

# 认证服务（登录）
# 开发环境 Vite 会把 /auth 代理到这个地址
VITE_AUTH_PROXY_TARGET=http://localhost:3101
# 生产/本地 auth server 端口
AUTH_PORT=3101
# 上游网关地址（auth server 会代理到此地址）
UPSTREAM_API_BASE_URL=https://s.lconai.com
# 服务端上游鉴权（不要使用 VITE_ 前缀）
UPSTREAM_AUTHORIZATION="Bearer sk-xxx"
# 上游并发保护（建议开启）
UPSTREAM_GUARD_ENABLED=true
# 单用户上游并发上限（默认 2）
UPSTREAM_MAX_INFLIGHT_PER_USER=2
# 全局上游并发上限（默认 12）
UPSTREAM_MAX_INFLIGHT_GLOBAL=12
# 触发并发保护时返回给前端的 Retry-After 秒数（默认 5）
UPSTREAM_GUARD_RETRY_AFTER_SEC=5
# 登录会话密钥（上线务必替换成强随机字符串）
AUTH_JWT_SECRET=replace-with-a-very-strong-secret
# 预置登录账号（你要求的默认用户）
AUTH_USER=guoboss
AUTH_PASSWORD=qazwsxedc1229
